# AURA 部署配置模板
# 用法: cp .env.example .env && 编辑 .env，然后:
#   set -a; source .env; set +a; bash start_all.sh

# ===== 必填 =====
# 指向你本机的 Qwen3-VL 或 Qwen3-Omni 模型目录
AURA_MODEL_PATH=/path/to/your/qwen3vl-8b/

# ===== 可选 (默认值如下) =====
# Flask 桥接层端口 (浏览器访问 http://host:此端口)
AURA_FLASK_PORT=5003

# 主推理服务 (Flask 桥接层连这里)
AURA_INFER_HOST=127.0.0.1
AURA_INFER_PORT=12345

# ASR / TTS 服务
AURA_ASR_PORT=8001
AURA_TTS_PORT=8002

# ===== GPU 分配 (start_all.sh 已支持) =====
GPU_ASR=0
GPU_TTS=0
GPU_INFERENCE=1
